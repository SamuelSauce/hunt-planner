{
  "name": "utah-hunt-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "ingest:data": "node scripts/ingest-udwr.mjs",
    "ingest:colorado": "node scripts/ingest-cpw.mjs",
    "ingest:idaho": "node scripts/ingest-idaho.mjs",
    "ingest:wyoming": "node scripts/ingest-wyoming.mjs",
    "ingest:boundaries": "node scripts/ingest-boundaries.mjs",
    "ingest:all": "npm run ingest:data && npm run ingest:colorado && npm run ingest:idaho && npm run ingest:wyoming && npm run ingest:boundaries",
    "build": "tsc -b && vite build && node scripts/generate-static-content.mjs && node scripts/prepare-sites-build.mjs",
    "content:build": "node scripts/generate-static-content.mjs",
    "content:validate": "node scripts/generate-static-content.mjs --validate-only",
    "content:map-card": "python3 scripts/generate-map-card.py",
    "seo:check": "node scripts/check-static-output.mjs",
    "sites:prepare": "node scripts/prepare-sites-build.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
